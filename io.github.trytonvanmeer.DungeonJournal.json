{
    "app-id": "io.github.trytonvanmeer.DungeonJournal",
    "runtime": "org.gnome.Platform",
    "runtime-version": "50",
    "sdk": "org.gnome.Sdk",
    "command": "dungeonjournal",
    "finish-args": [
        "--device=dri",
        "--share=network",
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--metadata=X-DConf=migrate-path=/io/github/trytonvanmeer/DungeonJournal/"
    ],
    "cleanup": [
        "/include",
        "/lib/pkgconfig",
        "/man",
        "/share/doc",
        "/share/gtk-doc",
        "/share/man",
        "/share/pkgconfig",
        "/share/vala",
        "*.la",
        "*.a"
    ],
    "modules": [
        {
            "name": "dungeonjournal",
            "buildsystem": "meson",
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/tryton-vanmeer/DungeonJournal",
                    "tag": "v0.7.0",
                    "commit": "b6e7ad3955c92897c0c9ac354e542b348323de13"
                }
            ]
        }
    ]
}

